<?xml version="1.0" encoding="utf-8" ?>
<sqlMapConfig
  xmlns="http://ibatis.apache.org/dataMapper"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <properties resource="properties.config"/>

  <settings>
    <setting useStatementNamespaces="true"/>
  </settings>

  <providers resource="providers.config"/>

  <!-- Database connection information -->
  <database>
    <!-- parameters ${xxxxx} arr defined within 'properties.config' -->
    <provider name="${providerSQLClient4}"/>
    <dataSource name="industry" connectionString="${connIndustry}" />
  </database>

  <sqlMaps>
    <!--基本屬性-->
    <sqlMap resource="./SqlMaps/Commons.xml" />
    <!--共用代碼-->
    <sqlMap resource="./SqlMaps/KeyMap.xml" />

    <sqlMap resource="./SqlMaps/Facade.xml" />
    <sqlMap resource="./SqlMaps/Teacher.xml" />
    <sqlMap resource="./SqlMaps/News.xml" />
    <sqlMap resource="./SqlMaps/Intro.xml" />
    <sqlMap resource="./SqlMaps/Account.xml" />
    <sqlMap resource="./SqlMaps/Log.xml" />
    <sqlMap resource="./SqlMaps/Course.xml" />
    <sqlMap resource="./SqlMaps/ShareFile.xml" />
    <sqlMap resource="./SqlMaps/Meeting.xml" />
    <sqlMap resource="./SqlMaps/DBTable.xml" />
    <sqlMap resource="./SqlMaps/Admin.xml" />
  </sqlMaps>

</sqlMapConfig>