{
    <div id="address">
        @Html.DropDownListFor(x => x.TeacherInfoForm.City, CommonOptions.Region(), null, new { id = "city", @class = "form-normal" })
        @Html.DropDownListFor(x => x.TeacherInfoForm.MemberDetail.zipcode, CommonOptions.Zip(Model.TeacherInfoForm.MemberDetail.zipcode), null, new { id = "region", @class = "form-normal" })
        @Html.TextBoxFor(x => x.TeacherInfoForm.MemberDetail.address, new { @class = "form-normal" })
    </div>

    <script>
        $(function () {
            var cityList = [];
            var root = $('#address');

            root.on('change', '#city', function (e) {
                city = e.target.value;
                syncZipList(city);
            });

            function refreshRegion(regionList) {
                var html = '';
                $.each(regionList, function (i, item) {
                    html += '<option value="' + item.zipcode + '">' + item.zipname + '</option>';
                });
                root.find('#region').html(html);
            }

            function syncZipList(city) {
                if (city) {
                    var newList = $.grep(cityList, function (item) {
                        return item.city === city;
                    });
                    refreshRegion(newList);
                }
            }

            function syncCityList(zipcode) {
                var filterList = $.grep(cityList, function (item) {
                    return item.zipcode === zipcode;
                });
                if (filterList && filterList.length > 0) {
                    var city = filterList[0].city;
                    root.find('#city').val(city);
                }
            }

            function getCityList() {
                $.ajax({
                    url: '@Url.Action("Ajax", "Member", new { id = ActionName.Member.CityZipCode })',
                    data: null,
                    method: 'POST'
                }).done(function (resp) {
                    if (resp && resp.data) {
                        cityList = resp.data;

                        var zipcode = root.find('#region').val();
                        syncCityList(zipcode);
                    }
                });
            }
            getCityList();
        });
    </script>
}

