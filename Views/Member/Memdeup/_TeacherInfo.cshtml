<script>
    $(function () {
        var root = $('#teacher-info');
        root.on('click', '#save', function (e) {
            e.preventDefault();
            $.ajax({
                url: root.find('#main_form').attr('action'),
                data: root.find('#main_form').serialize(),
                method: 'POST'
            }).done(function (resp) {
                if (resp && resp.status) {
                    blockAlert("儲存成功", null, function () {
                        window.location = '@Url.Action("Index", "Member", new { id = ActionName.Member.Home })';
                    });
                } else {
                    if (resp && resp.message) {
                        var res = '';
                        $.each(resp.message, function (i, item) {
                            res += item + '\n';
                        });
                        blockWarning(res);
                    }
                }
            });
        });
    });
</script>

@helper ShowoffRadio(int i)
{
    <label class="radio-inline">
        @*<input type="radio" name="showoff1" value="1" checked="">是*@
        @Html.RadioButtonFor(x => x.TeacherInfoForm.Showoff[i - 1], "1") 是
    </label>
    <label class="radio-inline">
        @*<input type="radio" name="showoff1" value="0"> 否*@
        @Html.RadioButtonFor(x => x.TeacherInfoForm.Showoff[i - 1], "0") 否
    </label>
}

@helper BirthDdl()
{
var years = Enumerable
    .Range(1950, DateTime.Now.Year - 18 - 1950)
    .Select(x => new SelectListItem { Value = x.ToString(), Text = x.ToString() })
    .ToList();

var months = Enumerable
    .Range(1, 12)
    .Select(x => new SelectListItem { Value = x.ToString(), Text = x.ToString() })
    .ToList();

var days = Enumerable
    .Range(1, 31)
    .Select(x => new SelectListItem { Value = x.ToString(), Text = x.ToString() })
    .ToList();

    @Html.DropDownListFor(x => x.TeacherInfoForm.BirthYear, years, "請選擇", new { @class = "form-normal" }) <span> 年 &nbsp;</span>
    @Html.DropDownListFor(x => x.TeacherInfoForm.BirthMonth, months, "請選擇", new { @class = "form-normal" }) <span> 月 &nbsp; </span>
    @Html.DropDownListFor(x => x.TeacherInfoForm.BirthDay, days, "請選擇", new { @class = "form-normal" }) <span> 日 </span>
}

@helper Region()
{
var list = CommonOptions.Region().Select(x => new CheckBoxListItem(x.Value, x.Text, false)).ToList();
    <div class="form-inline" style="margin-left:20px">
