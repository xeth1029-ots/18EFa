@using Turbo.MVC.Base3.Commons
@model Turbo.MVC.Base3.Models.MobileNumberModel

<div class="col-sm-10 form-inline">
    @Html.LabelFor(x => x.AreaCode, "區碼", new { @class = "sr-only" })
    @Html.TextBoxFor(m => m.AreaCode, new { size = "4", @class = "form-control", placeholder = "區碼", maxLength = "4" })
    －
    @Html.LabelFor(x => x.Number, "號碼", new { @class = "sr-only" })
    @Html.TextBoxFor(m => m.Number, new { size = "10", @class = "form-control", placeholder = "號碼", maxLength = "6" })
</div>
