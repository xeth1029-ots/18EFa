@model WDACC.Models.NewsModel
@using WDACC.Models.ViewModel.Facade
@using WDACC.Models.StoreExt
@using WDACC.Commons

@if (!Model.IsGridRowOnly)
{
    @RenderHomeGrid()
}
else
{
    @RenderHomeGridRows()
}

@helper RenderHomeGridRows()
{
    /* 置頂 */
    if (Model != null && Model.HotGrid != null)
    {
        for (int i = 0; i < Model.HotGrid.Count; i++)
        {
            var item = Model.HotGrid[i];
            <tr>
                <td>
                    <span class="glyphicon glyphicon-pushpin" aria-hidden="true"></span>
                </td>
                <td class="newsDate"> @item.Get("sdate").AsDateTimeText("yyyy/MM/dd") </td>
                <td>
                    <a href="@Url.Action("Detail", "Facade", new { id = FacadeViewModel.ActionName.News, NewsId = item.Get("id").AsInt32() })">
                        @Html.Raw(item.Get("title").AsHtmlDecodedText())
                    </a>
                </td>
                <td class="newsDate"> @item.Get("edate").AsDateTimeText("yyyy/MM/dd") </td>
            </tr>
        }
    }

    // 一般內容
    if (Model != null && Model.Grid != null)
    {
        for (int i = 0; i < Model.Grid.Count; i++)
        {
            var item = Model.Grid[i];
            <tr>
                <td>
                    @if (Model.Paging.PagingInfo.PageIdx > 1)
                    {
                        @CommonUtil.GetPageRowIndex(Model.Paging, i)
                    }
                    else
                    {
                        @(i+1)
                    }
                </td>
                <td class="newsDate"> @item.Get("sdate").AsDateTimeText("yyyy/MM/dd") </td>
                <td>
                    <a href="@Url.Action("Detail", "Facade", new { id = FacadeViewModel.ActionName.News, NewsId = item.Get("id").AsInt32() })">
                        @Html.Raw(item.Get("title").AsHtmlDecodedText())
                    </a>
                </td>
                <td class="newsDate"> @item.Get("edate").AsDateTimeText("yyyy/MM/dd") </td>
            </tr>
        }
    }
}

@helper RenderHomeGrid()
{
    <table width="100%" border="0" cellspacing="0" cellpadding="0" class="table-index table table-bordered">
        <tr>
            <th width="6%">項次</th>
            <th width="12%">發布日期</th>
            <th width="70%">公告標題</th>
            <th width="12%">截止日期</th>
        </tr>
        <tbody id="rows">
            @RenderHomeGridRows()
        </tbody>
    </table>
}

