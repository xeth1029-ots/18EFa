@{
    //ErrorPageController
    Layout = null;
    ViewBag.Title = "錯誤";
    ViewBag.SystemMsg1 = "系統發生異常!";
    ViewBag.HTitle3 = "歡迎光臨 共通核心職能專區";
}

<div>
    <h1 class="text-danger">@ViewBag.SystemMsg1</h1>
    <h2 style="font-size: 0em; margin: 0;">@ViewBag.HTitle3</h2>
    <p>@(ViewBag.Time)</p>
    <p>處理您的要求時發生錯誤，請聯絡管理人員!</p>
    @if (HttpContext.Current.Request.IsLocal && !String.IsNullOrEmpty(ViewBag.Message))
    {
        <div style="margin-top:20px">
            <p>@(ViewBag.Message)</p>
            @if (ViewBag.Exception != null)
            {
                Stack<string> trace = new Stack<string>();
                Exception ex = (Exception)ViewBag.Exception;
                trace.Push(ex.StackTrace);
                while (ex.InnerException != null)
                {
                    ex = ex.InnerException;
                    trace.Push(ex.StackTrace);
                }
                <pre>
                @while (trace.Count > 0)
                {
                    string msg = trace.Pop();
                    @Html.Raw( msg )       
                    if (trace.Count > 0)
                    {
                        @("\n--- 內部例外狀況堆疊追蹤的結尾 ---\n")
                    }
                }
                </pre>
            }
        </div>
    }
</div>

