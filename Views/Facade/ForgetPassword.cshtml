@model WDACC.Models.ViewModel.Facade.FacadeViewModel
@using WDACC.Models.ViewModel.Facade

@{
    ViewBag.Title = "忘記密碼";
    string action = ViewContext.RouteData.Values["action"].ToString();
}

@Html.Partial("_Breadcrumb")
@Html.Partial("_TitleBar")

@switch (action)
{
    case "Index":
        @RenderForm()
        break;
    case "Save":
        @RenderResult()
        break;
    default:
        break;
}

@helper RenderForm()
{
using (Html.BeginForm("Save", "Facade", new { id = FacadeViewModel.ActionName.ForgetPassword }, FormMethod.Post,
    new { id = "main_form", @class = "form-horizontal", autocomplete = "off" }))
{
        <div class="login-border">

            <div class="form-group">
                @*<label class="control-label col-sm-2"></label>*@
                <div class="col-sm-10" style="color: #CC0000">
                    忘記帳號請輸入身分證號，忘記密碼請輸入email帳號，生日欄位為西元年
                </div>
            </div>

            <div class="form-group">
                <label for="ForgetModel_Email" class="control-label col-sm-2">輸入帳號</label>
                <div class="col-sm-10">
                    @Html.TextBoxFor(x => x.ForgetModel.Email, new { @class = "form-normal", placeholder = "請輸入電子郵件或身分證號", size = "50", maxlength = "100" })
                </div>
            </div>
            <div class="form-group">
                @*<label for="ForgetModel_Birthday" class="control-label col-sm-2">生日</label>*@
                <label class="control-label col-sm-2">生日</label>
                <div class="col-sm-10">
                    @Html.EditorFor(x => x.ForgetModel.Birthday, "DateFieldInput")
                </div>
            </div>
            <div class="form-group">
                @*<label for="ForgetModel_ValidateCode" class="control-label col-sm-2">驗證碼</label>*@
                @Html.LabelFor(x => x.ForgetModel.ValidateCode, "請輸入驗證碼", new { @class = "control-label col-sm-2 mark-red" })
                <div class="col-sm-2">
                    @Html.TextBoxFor(x => x.ForgetModel.ValidateCode, new { @class = "form-control", title = "請輸入驗證碼", placeholder = "請輸入驗證碼", maxlength = "10" })
                </div>
                <div class="col-sm-8">
                    <img src="@Url.Action("GetValidateCode", "Login")" id="imgChkNum" alt="產生新驗證碼" title="驗證碼" />&nbsp;
                    @*<span style="color:red">點擊圖片可更換驗證碼</span>*@
                    @*<iframe name="frmPlayer" style="display:none;" src="" id="frmPlayerValidateCode" title="驗證碼語音撥放介面"></iframe>*@
                    <br />
                    <a href="javascript:void(0);" title="點擊刷新驗證碼" id="reflashNum"><span style="color:#CC0000">刷新驗證碼</span></a>
                    <a href="@Url.Action("GetValidateAudio", "Login")" target="frmPlayer" title="語音撥放驗證碼"><img id="playCode" alt="撥放" src="~/images/speaker.png" height="30" /></a>
                    <br />
                    <iframe name="frmPlayer" src="" title="驗證碼語音播放" scrolling="no" tabindex="-1" style="border: 0; width: 330px; height: 60px; display:inline-block;"></iframe>
                    <noscript> 不支援javascript時，請按鍵盤上的F5鍵以重新產生驗證碼。 </noscript>
                </div>
            </div>
            <div class="form-group">
                @*div class="col-sm-offset-2 col-sm-10"><p class="mark-red">※帳號最少8碼，且為英數組合，第一字不可為數字。<br>
                        ※密碼最少12碼，且有大小寫英文及數字之組合，不可有特殊符號。</p></div*@
                <div class="submit-bar">
                    <button type="submit" class="btn-orange" name="submit" id="submit" title="按下後查詢啟動">確定(查詢)</button>
                </div>
                <br />
                @if (TempData.ContainsKey("ErrorMessage"))
                {
                    <div class="alert alert-danger error-message">@(TempData["ErrorMessage"])</div>
                }
            </div>
        </div>
}

    <script>
        $(function () {
            var form = $('form#main_form');
            $('button[type=submit]').on('click', function (e) {
                e.preventDefault();
                $.ajax({
                    url: form.attr('action'),
                    data: form.serialize(),
                    method: 'POST'
                }).done(function (resp) {
                    if (resp) {
                        if (resp.status && resp.message) {
                            blockAlert(resp.message, null, function () {
                                window.location = '@Url.Action("Index", "Facade", new { id = FacadeViewModel.ActionName.Login })';
                            });
                        } else {
                            var res = '';
                            $.each(resp.message, function (i, item) { res += item + '\n'; })
                            reloadValidCode();
                            blockAlert(res);
                        }
                    }
                });
            });
        });
    </script>

    <script type="text/javascript">
        function reloadValidCode() {
            blockUI();
            $('#imgChkNum').attr("src", '@Url.Action("GetValidateCode", "Login")' + "?rand=" + new Date().getMilliseconds());
        }
        $(function () {
            $('#reflashNum').on("click", function (e) { reloadValidCode(); });
            $('#imgChkNum').on("click", function (e) { reloadValidCode(); });
            $('#imgChkNum').on("load", function () { unblockUI(); });
            //$('[data-toggle="tooltip"]').tooltip()
        });
    </script>
}

@helper RenderResult()
{
    <div class="login-border text-center">
        @Model.Message
    </div>
}

