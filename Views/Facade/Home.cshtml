@model WDACC.Models.ViewModel.Facade.FacadeViewModel
@using WDACC.Models.StoreExt
@using WDACC.Commons

@{
    Layout = "~/Views/Shared/_NewFullMainLayout.cshtml";
}

@Html.Partial("_Breadcrumb")

<div class="content container-fluid">
    <div class="row">
        @*style="background-image: linear-gradient(rgb(250, 255, 189) 14%, rgb(250, 255, 189) 14%, rgb(254, 252, 234) 94%);"*@
        <div class="col-md-12">
            @*<marquee id="idmq" scrollamount="3"></marquee>*@
            @if (Model.MarqueeList != null)
            {
                foreach (var item in Model.MarqueeList)
                {
                    <span>
                        ● @item.title (發布日期：@(item.sdate.HasValue ? item.sdate.Value.ToString("yyyy-MM-dd") : ""))
                        &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;
                        &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;
                        &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;
                        &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;
                    </span>
                }
            }
        </div>
        <div class="col-md-6">
            <h3 class="main-title titlebar-green">課程最新公告</h3>@*共通核心職能課程最新公告*@
            <div class="table-responsive">
                @Html.EditorFor(x => x.NewsGrid, "News")
                @*<table width="100%" border="0" cellspacing="0" cellpadding="0" class="table-index">
                <thead>
                    <tr>
                        <th width="6%" nowrap="">序號</th>
                        <th width="12%" nowrap="">發布日期</th>
                        <th width="70%">公告標題 </th>
                        <th width="12%" nowrap="">截止日期 </th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>*@
            </div>
        </div>
        <div class="col-md-6">
            <h3 class="main-title titlebar-green">師資授課花絮</h3>@*共通核心職能師資授課花絮*@
            <div class="panel panel-success">
                <div class="panel-body">
                    <div id="mainCarousel" class="carousel slide" data-ride="carousel">
                        <!-- Wrapper for slides -->
                        <div class="carousel-inner" role="listbox">
                            @if (Model.TeachShowGrid.Result != null && Model.TeachShowGrid.Result.Count > 0)
                            {
                                for (int i = 0; i < Model.TeachShowGrid.Result.Count; i++)
                                {
                                    var item = Model.TeachShowGrid.Result[i];
                                    string s_realname = item.Get("realname").AsText();
                                    string s_alt_title2 = item.Get("title").AsText();
                                    string s_url_image = Url.Action("Download", "File", new { id = ActionName.File.TeachShow, fid = item.Get("id").AsInt64() });
                                    <div class="field-content item @Html.Raw(i == 0 ? "active" : "")">
                                        <img class="youtube_thumb" src="@s_url_image" alt="@s_alt_title2" longdesc="@s_alt_title2" />
                                        <div class="carousel-caption"><h4 class="mark-blue">@s_realname</h4></div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="field-content item active">
                                    <img class="youtube_thumb" src="~/images/headerBg.jpg" alt="共通核心職能背景圖" />
                                    <div class="carousel-caption"> <h4 class="mark-blue">(資料筆數為0)</h4></div>
                                </div>
                            }
                        </div>

                        <!-- Left and right controls -->
                        <a class="left carousel-control" href="#mainCarousel" data-slide="prev">
                            <span class="glyphicon glyphicon-chevron-left"></span>
                            <span class="sr-only">Previous</span>
                        </a>
                        <a class="right carousel-control" href="#mainCarousel" data-slide="next">
                            <span class="glyphicon glyphicon-chevron-right"></span>
                            <span class="sr-only">Next</span>
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

