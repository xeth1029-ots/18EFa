@model WDACC.Models.ViewModel.Facade.FacadeViewModel
@using WDACC.Models.StoreExt

@{
    ViewBag.Title = "課程簡介";
}

@Html.Partial("_Breadcrumb")
@Html.Partial("_TitleBar")

<div class="submenu">
    <!-- Nav tabs -->
    <ul class="nav nav-tabs">
        <li class=""><a data-toggle="tab" href="#intro" aria-expanded="false">共通核心職能課程說明</a></li>
        <li class=""><a data-toggle="tab" href="#intro-dc" aria-expanded="false">動機職能－DC</a></li>
        <li class=""><a data-toggle="tab" href="#intro-bc" aria-expanded="false">行為職能－BC</a></li>
        <li class="active"><a data-toggle="tab" href="#intro-kc" aria-expanded="true">知識職能－KC</a></li>
    </ul>

    <!-- news content start -->
    <div class="news-content">
        <div class="tab-content">
            <div class="tab-pane fade" id="intro">
                @if (Model.CourseIntro != null)
                {
                    var intro1 = Model.CourseIntro
                        .Where(x => x.Get("id").AsInt64() == 6)
                        .FirstOrDefault().Get("content")
                        .AsHtmlDecodedText();
                    @Html.Raw(intro1)
                }
            </div>
            <div class="tab-pane fade" id="intro-dc">
                @if (Model.CourseIntro != null)
                {
                    var intro2 = Model.CourseIntro
                        .Where(x => x.Get("id").AsInt64() == 7)
                        .FirstOrDefault()
                        .Get("content")
                        .AsHtmlDecodedText();
                    @Html.Raw(intro2)
                }
            </div>
            <div class="tab-pane fade" id="intro-bc">
                @if (Model.CourseIntro != null)
                {
                    var intro3 = Model.CourseIntro
                        .Where(x => x.Get("id").AsInt64() == 8)
                        .FirstOrDefault()
                        .Get("content")
                        .AsHtmlDecodedText();
                    @Html.Raw(intro3)
                }
            </div>
            <div class="tab-pane fade active in" id="intro-kc">
                @if (Model.CourseIntro != null)
                {
                    var intro4 = Model.CourseIntro
                        .Where(x => x.Get("id").AsInt64() == 9)
                        .FirstOrDefault()
                        .Get("content")
                        .AsHtmlDecodedText();
                    @Html.Raw(intro4)
                }
            </div>
        </div>
    </div>
</div>

