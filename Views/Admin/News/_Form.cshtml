<script type="text/template" id="tmpl-file-row">
    <div class="row" style="width:98%">
        <div class="col-sm-5">
            <input type="file" name="Files" class="form-control" accept="@s_file_accept" />
        </div>
        <div class="col-sm-5">
             <input type="text" size="30" name="Comments" class="form-control" placeholder="檔案說明" />
        </div>
        <div class="col-sm-1">
        </div>
    </div>
</script>

<script>
    $(function () {
        var root = $('div#news_form');

        root.on('click', '#save', function (e) {
            e.preventDefault();

            var content = CKEDITOR.instances['news_form_content'].getData();
            var newcontent = $('<div/>').text(content).html();
            root.find('#news_form_content').val(newcontent);

            $.ajax({
                url: root.find('#main_form').attr('action'),
                data: new FormData(root.find('#main_form')[0]),
                method: 'POST',
                contentType: false,
                processData: false
            }).done(function (resp) {
                if (resp && resp.status) {
                    blockAlert("儲存成功", null, function () {
                        window.location = '@Url.Action("Index", "Admin", new { id = ActionName.Admin.News })';
                    });
                }
            });
        });

        root.on('click', '#fabtn', function (e) {
            e.preventDefault();
            var html = $('#tmpl-file-row').html();
            $("#row-container").append(html);
        });

        root.on('change', 'input[type=file]', function (e) {
            e.preventDefault();
            var file = e.target.files[0];
            var ext = file.name.split('.').pop().toUpperCase() || '';
            if (ext && ext != 'ODT' && ext != 'ODP' && ext != 'ODS' && ext != 'PDF') {
                var msg = '網站全面以ODF類型檔案(如：ODT、ODP、ODS、PDF)為優先文件格式!';
                blockAlert(msg, null, null);
            }
        });

        CKEDITOR.replace('news_form_content', {
            htmlEncodeOutput: false 
        });
    });
</script>
