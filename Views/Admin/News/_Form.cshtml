            @{ 
                string label = string.Empty;
                if (Model.Action == ActionName.Admin.News)
                {
                    label = "新增公告";
                }
                else
                {
                    label = "修改公告";
                }
            }
            <button type="submit" id="save" class="btn btn-orange">@label</button>
