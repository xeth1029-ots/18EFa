@using Turbo.MVC.Base3.Areas.A6.Models;
@model C101MFormModel

@if (Model.Grid != null)
{
    for (int i = 0; i < Model.Grid.Count; i++)
    {
        var item = Model.Grid[i];
        <tr>
            <td align="center"><button type="button" class="btn btn-info" onclick="doModify('@item.user_name','@item.user_username')">編修</button></td>
            <td align="center">@item.sys_id</td>
            <td align="center">@item.user_org</td>
            <td align="center">@item.user_name</td>
            <td align="center">@item.user_username</td>
            <td align="center">@item.indate</td>
            <td align="center">@item.user_enabled</td>
            <td align="center"><button type="button" class="btn btn-info" onclick="doSetPower('@item.user_name','@item.user_username')">設定群組</button></td>
        </tr>
    }
}
