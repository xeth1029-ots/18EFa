<?xml version="1.0" encoding="utf-8" ?>
<sqlMap namespace="Meeting"
xmlns="http://ibatis.apache.org/mapping"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" >

  <resultMaps>
  </resultMaps>

  <cacheModel id="WDASE-cache" implementation="MEMORY" >
    <flushInterval hours="1"/>
    <property name="Type" value="WEAK"/>
  </cacheModel>

  <statements>
    <!-- 師資會議積分清單 -->
    <select id="GetMemberMeetScoreList"
        resultClass="WDACC.Models.StoreExt.Store"
        parameterClass="Hashtable"
        cacheModel="WDASE-cache">
      <![CDATA[
        select
          a.mid,
          a.score,
          a.mcont,
          b.date,
          b.mclass,
          b.metname
        from metdetail a join meeting b on a.metid=b.id
        where 1=1
      ]]>
      <dynamic>
        <isNotEmpty property="id">
          <![CDATA[ and b.id = #id# ]]>
        </isNotEmpty>
        <isNotEmpty property="mid">
          <![CDATA[ and a.mid = #mid# ]]>
        </isNotEmpty>
        <isNotEmpty property="year">
          <![CDATA[ and year(b.date) = #year# ]]>
        </isNotEmpty>
        <isNotEmpty property="mclass">
          <![CDATA[ and b.mclass = #mclass# ]]>
        </isNotEmpty>
      </dynamic>
      <![CDATA[ order by date desc ]]>
    </select>


  </statements>
</sqlMap>
